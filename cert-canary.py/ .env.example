# ─────────────────────────────────────────────
# cert-canary — .env.example
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# .env is in .gitignore — never commit real credentials.
# In CI/CD, set these as repository secrets instead.
# ─────────────────────────────────────────────


# ── Slack ─────────────────────────────────────
# Incoming webhook URL from:
# Slack → Your App → Incoming Webhooks → Add New Webhook
#
CANARY_SLACK_WEBHOOK=https://hooks.slack.com/services/TXXXXXXXX/BXXXXXXXX/XXXXXXXXXXXXXXXXXXXXXXXX


# ── Discord ───────────────────────────────────
# Webhook URL from:
# Discord Server → Edit Channel → Integrations → Webhooks → New Webhook
#
CANARY_DISCORD_WEBHOOK=https://discord.com/api/webhooks/000000000000000000/XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX


# ── PagerDuty ─────────────────────────────────
# Events API v2 routing key from:
# PagerDuty → Services → Your Service → Integrations → Add Integration → Events API v2
#
# This key TRIGGERS and RESOLVES incidents — keep it private.
#
CANARY_PAGERDUTY_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX


# ── Generic Webhook ───────────────────────────
# Any endpoint that accepts a JSON POST.
# cert-canary will send the full scan payload here.
# Optionally set CANARY_WEBHOOK_SECRET for HMAC-SHA256
# request signing (X-Canary-Signature header).
#
CANARY_WEBHOOK_URL=https://your-endpoint.example.com/hooks/certs
CANARY_WEBHOOK_SECRET=a-long-random-string-you-generate


# ── SMTP (email) ──────────────────────────────
# SMTP config can't be passed as a single env var,
# so email is configured in canary.json instead.
# See canary.json.example → "smtp" block.
#
# If you use Gmail:
#   - Enable 2FA on the account
#   - Generate an App Password (not your real password)
#   - Use port 587 with starttls: true
#
# If you use SendGrid:
#   - SMTP host: smtp.sendgrid.net
#   - User: apikey (literally the string "apikey")
#   - Password: your SendGrid API key


# ─────────────────────────────────────────────
# Loading .env in different environments
# ─────────────────────────────────────────────
#
# Local dev (bash):
#   export $(grep -v '^#' .env | xargs)
#   python3 main.py --hosts hosts.txt --once
#
# Local dev (fish):
#   export (grep -v '^#' .env | xargs -L1)
#
# Docker:
#   docker run --env-file .env cert-canary
#
# Docker Compose:
#   env_file:
#     - .env
#
# systemd:
#   EnvironmentFile=/opt/cert-canary/.env
#
# GitHub Actions — do NOT use .env, use secrets:
#   env:
#     CANARY_SLACK_WEBHOOK: ${{ secrets.CANARY_SLACK_WEBHOOK }}
#     CANARY_PAGERDUTY_KEY: ${{ secrets.CANARY_PAGERDUTY_KEY }}